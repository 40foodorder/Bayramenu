<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
    <TextView android:id="@+id/tvCartItemName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="16sp" android:textStyle="bold"/>
    <Button android:id="@+id/btnMinus" android:layout_width="40dp" android:layout_height="40dp" android:text="-" style="?attr/borderlessButtonStyle"/>
    <TextView android:id="@+id/tvCartItemQty" android:layout_width="wrap_content" android:layout_height="wrap_content" android:padding="8dp" android:text="1" android:textSize="16sp"/>
    <Button android:id="@+id/btnPlus" android:layout_width="40dp" android:layout_height="40dp" android:text="+" style="?attr/borderlessButtonStyle"/>
    <TextView android:id="@+id/tvCartItemPrice" android:layout_width="80dp" android:layout_height="wrap_content" android:gravity="end" android:text="0 ETB" android:textStyle="bold" android:textColor="#2196F3"/>
</LinearLayout>
